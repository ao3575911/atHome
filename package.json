{
  "name": "@home/root",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.4",
  "scripts": {
    "dev": "npm run dev -w @home/api",
    "demo": "tsx scripts/demo.ts",
    "format": "prettier --write .",
    "generate:sdk": "tsx scripts/generate-sdk.ts",
    "lint": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev:web": "npm run dev -w @home/web",
    "build:web": "npm run build -w @home/web",
    "typecheck:web": "npm run typecheck -w @home/web"
  },
  "dependencies": {
    "@home/protocol": "0.1.0",
    "@home/sdk": "0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.8.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
