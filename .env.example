# @home local API configuration
# Copy to .env.local or export variables in your shell before running pnpm dev.

# API bind settings
HOST=127.0.0.1
PORT=3000

# Local demo storage directory. Defaults to ./data when unset.
DATA_DIR=./data

# Local demo/dev only. Returns bootstrap private keys from create/register routes.
# Never enable in production.
ATHOME_DEMO_PRIVATE_KEY_EXPORT=false

# Production hardening toggle used by the API to disable bootstrap/private-key export flows.
NODE_ENV=development
